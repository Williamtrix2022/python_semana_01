#Pide un número al usuario y muestra todos los números del 1 hasta ese número que sean múltiplos de 3.

print("EJERCICIO 1: Mostrar múltiplos de 3")
numero = int(input("Ingrese un número: "))
print(f"Números del 1 al {numero} que son múltiplos de 3:")
for i in range(1, numero + 1):
    if i % 3 == 0:
        print(i)
        