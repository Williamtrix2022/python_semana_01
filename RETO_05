#Desafío: FizzBuzz clásico — imprime los números del 1 al 50. Si es múltiplo de 3 imprime "Fizz", si es múltiplo de 5 imprime "Buzz", si es múltiplo de ambos imprime "FizzBuzz".

print ("EJERCICIO 1: FizzBuzz clásico")
for i in range(1, 51):
    if i % 3 == 0 and i % 5 == 0 :
        print("FizzBuzz")
    elif i % 3 == 0:
        print("Fizz")
    elif i % 5 == 0:
        print("Buzz")
    else:
        print(i)